<!-- Placeholder para textura de tecido macro para Decoração -->
<svg width="400" height="300" xmlns="http://www.w3.ogit rg/2000/svg">
  <defs>
    <pattern id="fabric" x="0" y="0" width="40" height="40" patternUnits="userSpaceOnUse">
      <rect width="40" height="40" fill="#f5f5f0"/>
      <circle cx="20" cy="20" r="2" fill="#e8e8e0" opacity="0.5"/>
      <line x1="0" y1="20" x2="40" y2="20" stroke="#e0e0d8" stroke-width="0.5" opacity="0.3"/>
      <line x1="20" y1="0" x2="20" y2="40" stroke="#e0e0d8" stroke-width="0.5" opacity="0.3"/>
    </pattern>
    <filter id="blur">
      <feGaussianBlur in="SourceGraphic" stdDeviation="0.5"/>
    </filter>
  </defs>
  <rect width="400" height="300" fill="url(#fabric)" filter="url(#blur)"/>
  <rect width="400" height="300" fill="#8B7355" opacity="0.3"/>
</svg>
