<!-- Placeholder para textura de madeira macro para Materiais -->
<svg width="400" height="300" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <pattern id="wood" x="0" y="0" width="60" height="120" patternUnits="userSpaceOnUse">
      <rect width="60" height="120" fill="#D4A574"/>
      <rect x="0" y="0" width="60" height="2" fill="#C19660" opacity="0.6"/>
      <rect x="0" y="20" width="60" height="1" fill="#C19660" opacity="0.4"/>
      <rect x="0" y="40" width="60" height="3" fill="#C19660" opacity="0.7"/>
      <rect x="0" y="60" width="60" height="1" fill="#C19660" opacity="0.3"/>
      <rect x="0" y="80" width="60" height="2" fill="#C19660" opacity="0.5"/>
      <rect x="0" y="100" width="60" height="1" fill="#C19660" opacity="0.4"/>
      <line x1="0" y1="0" x2="0" y2="120" stroke="#B8956A" stroke-width="0.5" opacity="0.3"/>
      <line x1="30" y1="0" x2="30" y2="120" stroke="#B8956A" stroke-width="0.5" opacity="0.2"/>
      <line x1="60" y1="0" x2="60" y2="120" stroke="#B8956A" stroke-width="0.5" opacity="0.3"/>
    </pattern>
    <filter id="blur">
      <feGaussianBlur in="SourceGraphic" stdDeviation="0.3"/>
    </filter>
  </defs>
  <rect width="400" height="300" fill="url(#wood)" filter="url(#blur)"/>
  <rect width="400" height="300" fill="#8B7355" opacity="0.2"/>
</svg>
